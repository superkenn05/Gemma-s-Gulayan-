rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperadmin() {
      return isSignedIn() && request.auth.token.email == 'markkenmadrid05@gmail.com';
    }

    // Simplified admin check to prevent recursive rule evaluation
    function isAdmin() {
      let path = /databases/$(database)/documents/staffUsers/$(request.auth.uid);
      return isSignedIn() && (isSuperadmin() || (exists(path) && get(path).data.role in ['Admin', 'Superadmin']));
    }

    // --- User Profiles ---
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      // Recursive wildcard ensures all subcollections (addresses, wishlist, orders, notifications) 
      // are accessible by the owner or an admin.
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Staff Management ---
    match /staffUsers/{staffId} {
      allow read, write: if isOwner(staffId) || isSuperadmin();
      allow read: if isAdmin();
      allow get: if !isSignedIn() && staffId.size() > 5;
    }

    // --- Public Collections (Storefront) ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    match /stockTransactions/{transactionId} {
      allow read, create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Store Configuration ---
    match /storeConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Explicit deny for any other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}